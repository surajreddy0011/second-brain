# Copy this file to .env and fill in real values.
# .env should be in .gitignore — never commit real secrets.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/second_brain

# You'll need this starting Day 7-8 for embeddings/chat.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# You'll generate this yourself on Day 3 — any long random string works.
# Example: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
